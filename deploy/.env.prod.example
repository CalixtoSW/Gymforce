# ─── APP ───
APP_ENV=production
APP_DEBUG=false

# ─── BANCO ───
POSTGRES_DB=gymforce
POSTGRES_USER=gymforce_prod
POSTGRES_PASSWORD=GERAR_SENHA_FORTE_64_CHARS
DATABASE_URL=postgresql+asyncpg://gymforce_prod:MESMA_SENHA@postgres:5432/gymforce

# ─── REDIS ───
REDIS_PASSWORD=GERAR_OUTRA_SENHA_FORTE
REDIS_URL=redis://:MESMA_SENHA_REDIS@redis:6379/0

# ─── AUTH ───
JWT_SECRET_KEY=GERAR_SECRET_64_CHARS_RANDOM
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── CORS ───
CORS_ORIGINS=https://admin.gymforce.app,https://gymforce.app

# ─── DOMINIOS ───
API_DOMAIN=api.gymforce.app
ADMIN_DOMAIN=admin.gymforce.app

# ─── MERCADO PAGO (PRODUCAO) ───
MP_ACCESS_TOKEN=APP_USR-xxxx
MP_PUBLIC_KEY=APP_USR-xxxx
MP_WEBHOOK_SECRET=xxxx
MP_PIX_EXPIRATION_MINUTES=30

# ─── CERTBOT ───
CERTBOT_EMAIL=calixto@gymforce.app
